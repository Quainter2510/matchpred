# Database
DATABASE_URL=postgresql+asyncpg://wc2026:wc2026@localhost:5432/wc2026

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-to-a-random-string-min-32-bytes-long
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

# Yandex OAuth
YANDEX_CLIENT_ID=your-client-id
YANDEX_CLIENT_SECRET=your-client-secret
YANDEX_REDIRECT_URI=https://your-domain.com/api/v1/auth/yandex/callback

# VK community bot (Callback API)
VK_GROUP_TOKEN=your-community-access-token
VK_GROUP_ID=123456789
VK_CONFIRMATION=confirmation-string-from-vk
VK_SECRET=your-callback-secret
VK_API_VERSION=5.199

# API Football
API_FOOTBALL_KEY=your-api-key
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
